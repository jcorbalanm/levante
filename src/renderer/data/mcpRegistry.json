    {
      "id": "supabase",
      "name": "Supabase",
      "description": "Access Supabase database and API through MCP",
      "category": "database",
      "icon": "database",
      "logoUrl": "https://supabase.com/brand-assets/supabase-logo-icon.png",
      "status": "active",
      "npmPackage": null,
      "version": "1.0.0",
      "transport": {
        "type": "http",
        "autoDetect": false
      },
      "configuration": {
        "fields": [
          {
            "key": "SUPABASE_PROJECT_REF",
            "label": "Supabase Project Reference",
            "type": "text",
            "required": true,
            "description": "Your Supabase project reference ID (found in project settings)",
            "placeholder": "abcdefghijklmnop"
          },
          {
            "key": "SUPABASE_ACCESS_TOKEN",
            "label": "Supabase Access Token",
            "type": "password",
            "required": true,
            "description": "Your Supabase access token for authentication",
            "placeholder": "sbp_xxxxxxxxxxxxxxxxxxxx"
          }
        ],
        "defaults": {},
        "template": {
          "type": "http",
          "baseUrl": "https://mcp.supabase.com/mcp?project_ref=${SUPABASE_PROJECT_REF}",
          "headers": {
            "Authorization": "Bearer ${SUPABASE_ACCESS_TOKEN}"
          }
        }
      }
    }
  ],
