      "category": "documentation",
      "icon": "book",
      "logoUrl": "https://learn.microsoft.com/media/logos/logo-ms-social.png",
      "status": "active",
      "npmPackage": null,
      "version": "1.0.0",
      "transport": {
        "type": "http",
        "autoDetect": false
      },
      "configuration": {
        "fields": [
          {
            "key": "baseUrl",
            "label": "API Base URL",
            "type": "text",
            "required": true,
            "description": "Microsoft Learn MCP API endpoint",
            "placeholder": "https://learn.microsoft.com/api/mcp",
            "defaultValue": "https://learn.microsoft.com/api/mcp"
