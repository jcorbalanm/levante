            "type": "text",
            "required": true,
            "description": "Path to the MCP server executable",
            "placeholder": "npx",
            "defaultValue": "npx"
          },
          {
            "key": "args",
            "label": "Command Arguments",
            "type": "text",
            "required": true,
            "description": "Arguments including package name",
            "placeholder": "@playwright/mcp@latest",
            "defaultValue": "@playwright/mcp@latest"
          }
        ],
        "defaults": {
          "command": "npx",
