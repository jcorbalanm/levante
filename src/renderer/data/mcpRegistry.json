{
  "version": "2.0.0",
  "lastUpdated": "2025-01-14",
  "entries": [
    {
      "id": "context7",
      "name": "Context7",
      "description": "Access up-to-date documentation and code examples for any library",
      "category": "documentation",
      "icon": "book",
      "logoUrl": "https://raw.githubusercontent.com/upstash/context7-mcp/main/logo.svg",
      "status": "active",
      "npmPackage": "@upstash/context7-mcp",
      "version": "latest",
      "transport": {
        "type": "stdio",
        "autoDetect": false
      },
      "configuration": {
        "fields": [
          {
            "key": "command",
            "label": "MCP Server Command",
            "type": "text",
            "required": true,
            "description": "Path to the MCP server executable",
            "placeholder": "npx",
            "defaultValue": "npx"
          },
          {
            "key": "args",
            "label": "Command Arguments",
            "type": "text",
            "required": true,
            "description": "Arguments including package name",
            "placeholder": "-y @upstash/context7-mcp@latest",
            "defaultValue": "-y @upstash/context7-mcp@latest"
          }
        ],
        "defaults": {
          "command": "npx",
          "args": "-y @upstash/context7-mcp@latest"
        },
        "template": {
          "type": "stdio",
          "command": "npx",
          "args": ["-y", "@upstash/context7-mcp@latest"],
          "env": {}
        }
      }
    },
    {
      "id": "github",
      "name": "GitHub Copilot MCP",
      "description": "Access GitHub repositories and code through Copilot MCP API",
      "category": "development",
      "icon": "github",
      "logoUrl": "https://github.githubassets.com/images/modules/logos_page/GitHub-Mark.png",
      "status": "active",
      "npmPackage": null,
      "version": "1.0.0",
      "transport": {
        "type": "http",
        "autoDetect": false
      },
      "configuration": {
        "fields": [
          {
            "key": "baseUrl",
            "label": "API Base URL",
            "type": "text",
            "required": true,
            "description": "GitHub Copilot MCP API endpoint",
            "placeholder": "https://api.githubcopilot.com/mcp/",
            "defaultValue": "https://api.githubcopilot.com/mcp/"
          },
          {
            "key": "github_mcp_pat",
            "label": "GitHub Personal Access Token",
            "type": "password",
            "required": true,
            "description": "Your GitHub Personal Access Token for authentication",
            "placeholder": "ghp_xxxxxxxxxxxxxxxxxxxx"
          }
        ],
        "defaults": {
          "baseUrl": "https://api.githubcopilot.com/mcp/"
        },
        "template": {
          "type": "http",
          "baseUrl": "https://api.githubcopilot.com/mcp/",
          "headers": {
            "Authorization": "Bearer ${github_mcp_pat}"
          }
        }
      }
    },
    {
